    }

    .submenu-link.sub-active {
      color: #dc2626;
      font-weight: bold;
    }
  }

  /* 7. PAGEFIND PANEL CUSTOM OVERRIDES */
  .pagefind-ui__drawer {
    position: relative !important;
  }

  .pagefind-ui__drawer::before {
    content: "✕";
