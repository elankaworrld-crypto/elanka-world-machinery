---
import Layout from '../layouts/Layout.astro';
// High-Performance B2B Industrial Sub-Homepage for Packaging Materials & Consumables
---

<Layout title="Industrial Packaging Materials & Supplies Sri Lanka | E Lanka World">
	
	<main>
		<!-- HERO SECTION -->
		<section class="materials-hero-container">
			<picture>
				<source srcset="/products/industrial-packaging-materials-sri-lanka.webp" type="image/webp" />
				<img 
					src="/products/industrial-packaging-materials-sri-lanka.png" 
					alt="Industrial Packaging Materials and Machine Consumables by E Lanka World International" 
					class="materials-hero-img" 
					loading="eager"
					width="1200"
					height="675"
				/>
			</picture>

			<div class="materials-hero-overlay">
				<div class="materials-lang-stack">
					<span class="sinhala">කාර්මික ඇසුරුම් ද්‍රව්‍ය සහ පරිභෝජන ද්‍රව්‍ය</span>
					<span class="tamil">தொழில்துறை பேக்கேஜிங் பொருட்கள் மற்றும் நுகர்பொருட்கள்</span>
				</div>
				<h1>Packaging Materials in Sri Lanka</h1>
				<h2>High-Grade B2B Consumables from E Lanka World International</h2>
				
				<div class="materials-cta-group">
					<a href="https://wa.me/94776344758" class="materials-whatsapp-btn">Inquire Material Wholesale</a>
				</div>
			</div>
		</section>

		<!-- PRODUCT CATEGORIES HUB -->
		<section class="materials-offer-section">
			<div class="materials-container">
				<h2 class="materials-section-title">Our Specialized Material Categories</h2>
				<p class="materials-section-subtitle">Premium industrial consumables engineered to run smoothly through automatic packaging lines.</p>
				
				<div class="materials-grid-hub">
					
					<!-- Card 1: Bubble Wrap -->
					<article class="materials-hub-card">
						<div class="materials-card-image">
							<img 
								src="/products/Bubble-wrap-in-srilanka.webp" 
								alt="Protective Air Bubble Wrap Rolls Sri Lanka" 
								width="1200"
								height="675"
								loading="lazy"
								decoding="async"
							/>
						</div>
						<div class="materials-card-body">
							<h3>Protective Bubble Wrap</h3>
							<p>Heavy-duty, shock-absorbing air bubble wrap rolls designed for superior surface protection, cushioning, and safe transit handling of industrial and fragile goods.</p>
							<a href="https://wa.me/94776344758" class="materials-card-link">Request Bulk Quote &rarr;</a>
						</div>
					</article>

					<!-- Card 2: Cling Wrap -->
					<article class="materials-hub-card">
						<div class="materials-card-image">
							<img 
								src="/products/Cling-wrap-in-srilanka.webp" 
								alt="Industrial Grade Cling Wrap and Stretch Pallet Film" 
								width="1200"
								height="675"
								loading="lazy"
								decoding="async"
							/>
						</div>
						<div class="materials-card-body">
							<h3>Industrial Cling & Stretch Wrap</h3>
							<p>High-elongation pallet stretch wrap and puncture-resistant cling wraps tailored for secure unitization, manual containment, or automatic wrapping machine integration.</p>
							<a href="https://wa.me/94776344758" class="materials-card-link">Request Bulk Quote &rarr;</a>
						</div>
					</article>

					<!-- Card 3: Cup Sealing Material -->
					<article class="materials-hub-card">
						<div class="materials-card-image">
							<img 
								src="/products/cup-sealing-material-in-srilanka.webp" 
								alt="Custom Printed Cup Sealing Machine Film Rolls" 
								width="1200"
								height="675"
								loading="lazy"
								decoding="async"
							/>
						</div>
						<div class="materials-card-body">
							<h3>Cup Sealing Machine Films</h3>
							<p>Premium polythene and aluminum foil laminate rolls custom-engineered for smooth unrolling and crisp cuts in automatic cup filling and sealing machinery.</p>
							<a href="https://wa.me/94776344758" class="materials-card-link">Request Bulk Quote &rarr;</a>
						</div>
					</article>

					<!-- Card 4: PP Strap Material -->
					<article class="materials-hub-card">
						<div class="materials-card-image">
							<img 
								src="/products/PP-strap-material-in-srilanka.webp" 
								alt="Machine Grade Polypropylene PP Strapping Rolls" 
								width="1200"
								height="675"
								loading="lazy"
								decoding="async"
							/>
						</div>
						<div class="materials-card-body">
							<h3>Machine-Grade PP Strapping</h3>
							<p>High-tensile polypropylene (PP) strap material rolls built to feed flawlessly through semi-automatic or fully automated factory box bundling machines.</p>
							<a href="https://wa.me/94776344758" class="materials-card-link">Request Bulk Quote &rarr;</a>
						</div>
					</article>

					<!-- Card 5: Celo Tapes -->
					<article class="materials-hub-card">
						<div class="materials-card-image">
							<img 
								src="/products/celo-tapes-in-srilanka.webp" 
								alt="Heavy Duty Carton Sealing Celo Tapes" 
								width="1200"
								height="675"
								loading="lazy"
								decoding="async"
							/>
						</div>
						<div class="materials-card-body">
							<h3>Carton Sealing Celo Tapes</h3>
							<p>High-tack, industrial-grade adhesive packaging tapes perfect for manual hand dispensers as well as automatic production-line case sealing equipment.</p>
							<a href="https://wa.me/94776344758" class="materials-card-link">Request Bulk Quote &rarr;</a>
						</div>
					</article>

				</div>

				<div class="materials-extra-offer">
					<p>Need customized dimensions or custom logo printing on your films and tapes?</p>
					<a href="/shop" class="materials-secondary-btn">Return to Machinery Shop</a>
				</div>
			</div>
		</section>

		<!-- SEO LONG-FORM ARTICLE SECTION -->
		<section class="materials-seo-section">
			<div class="materials-container">
				<h2 class="materials-article-title">High-Performance Packaging Consumables for Industrial Automation</h2>
				
				<div class="materials-article-grid">
					<div class="materials-article-text">
						<h3>Seamless Integration with Packaging Machinery</h3>
						<p>
							Finding reliable <strong>packaging material in Sri Lanka</strong> that doesn't snap, jam, or warp inside automated machinery can be an ongoing factory floor challenge. At <strong>E Lanka World International</strong>, we supply materials specifically matched to technical machine tolerances. Whether you are running high-speed carton sealers or heavy strapping units, our consumables ensure your factory output remains at maximum velocity.
						</p>

						<h3>Optimizing Unitization & Transit Security</h3>
						<p>
							Substandard wrapping and strapping are primary causes of industrial product damage during local logistics transit. Employing premium, heavy-gauge <strong>PP strap material in Sri Lanka</strong> alongside high-cling multi-layer wraps guarantees rigid pallet stabilization. This rigorous unitization minimizes product shifting, protects outer cartons from crushing forces, and preserves product presentation from factory gate to distribution points.
						</p>
					</div>

					<div class="materials-article-text">
						<h3>High-Barrier Freshness & Advanced Leak Protection</h3>
						<p>
							For commercial food and beverage bottling, fast-moving dairy operations, and takeaway packaging, sealing reliability is absolute. Selecting verified <strong>cup sealing material in Sri Lanka</strong> ensures clean thermo-bonding and zero leaks. Our plastic and aluminum foil laminate roll structures are precisely treated to accept crisp commercial print work while withstanding rapid pneumatic heat-sealing actions cleanly.
						</p>

						<h3>Reliable Bulk Supplies & Commercial Material Logistics</h3>
						<p>
							A manufacturing line is only as fast as its available raw material reserves. Rather than facing production delays due to material stock-outs, businesses trust our inventory supply lines. From shock-absorbing <strong>bubble wrap in Sri Lanka</strong> to automated packaging consumables, we provide dependable commercial scale options, tier discounts, and responsive technical advice to optimize your operation's bottom line.
						</p>
					</div>
				</div>

				<!-- CALL TO ACTION BANNER -->
				<div class="materials-cta-banner">
					<p>Ready to request a bulk wholesale quotation or verify material test compatibility with your current machinery?</p>
					<a href="https://wa.me/94776344758" class="materials-primary-btn">Talk to Material Experts Now</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	/* --- HERO BLOCK STYLING --- */
	.materials-hero-container {
		position: relative;
		width: 100%;
		min-height: 75vh;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		background-color: #0f172a;
	}

	.materials-hero-img {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: 1;
		opacity: 0.85;
	}

	.materials-hero-overlay {
		position: relative;
		z-index: 2;
		background: rgba(255, 255, 255, 0.95);
		padding: 2.5rem;
		border-radius: 15px;
		text-align: center;
		max-width: 820px;
		margin: 0 1rem;
		backdrop-filter: blur(8px);
		box-shadow: 0 10px 30px rgba(0,0,0,0.25);
	}

	.materials-hero-overlay h1 {
		font-size: clamp(1.8rem, 4.5vw, 2.8rem);
		color: #001f3f;
		line-height: 1.2;
		margin: 0.5rem 0 1rem 0;
		font-weight: 800;
	}

	.materials-hero-overlay h2 {
		font-size: 1.15rem;
		color: #2563eb;
		margin-bottom: 1.5rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}
	
	.materials-lang-stack span {
		display: block;
		font-size: 0.9rem;
		color: #4b5563;
		margin-bottom: 4px;
		font-weight: 500;
	}

	.materials-whatsapp-btn {
		background: #25D366;
		color: white;
		padding: 0.9rem 2.2rem;
		border-radius: 50px;
		text-decoration: none;
		font-weight: bold;
		display: inline-block;
		transition: transform 0.2s, background-color 0.2s;
		box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
	}
	.materials-whatsapp-btn:hover {
		transform: scale(1.03);
		background-color: #20ba5a;
	}

	/* --- PRODUCT GRID HUB STYLING --- */
	.materials-offer-section {
		padding: 5rem 1.5rem;
		background-color: #f8fafc;
	}
	
	.materials-container {
		max-width: 1200px;
		margin: 0 auto;
		text-align: center;
	}
	
	.materials-section-title {
		font-size: 2.3rem;
		color: #001f3f;
		margin-bottom: 0.75rem;
		font-weight: 800;
	}
	
	.materials-section-subtitle {
		color: #64748b;
		margin-bottom: 3.5rem;
		font-size: 1.05rem;
	}

	.materials-grid-hub {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		text-align: left;
	}

	.materials-hub-card {
		background: #ffffff;
		border-radius: 12px;
		box-shadow: 0 4px 20px rgba(0,0,0,0.04);
		border-top: 5px solid #2563eb;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}
	
	.materials-hub-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 8px 25px rgba(0,0,0,0.08);
	}

	.materials-card-image {
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background-color: #e2e8f0;
	}

	.materials-card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.materials-card-body {
		padding: 1.8rem;
		display: flex;
		flex-direction: column;
		flex-grow: 1;
	}

	.materials-card-body h3 {
		color: #001f3f;
		font-size: 1.3rem;
		margin-bottom: 0.75rem;
		padding-bottom: 0.5rem;
		border-bottom: 2px solid #f1f5f9;
		font-weight: 700;
	}
	
	.materials-card-body p {
		color: #475569;
		font-size: 0.95rem;
		line-height: 1.6;
		margin-bottom: 1.5rem;
		flex-grow: 1;
	}

	.materials-card-link {
		color: #2563eb;
		text-decoration: none;
		font-weight: 700;
		font-size: 0.95rem;
		display: inline-flex;
		align-items: center;
	}
	
	.materials-card-link:hover {
		text-decoration: underline;
		color: #1d4ed8;
	}

	.materials-extra-offer {
		margin-top: 4rem;
		color: #475569;
		font-weight: 500;
	}
	
	.materials-secondary-btn {
		display: inline-block;
		margin-top: 1.2rem;
		color: #2563eb;
		text-decoration: none;
		font-weight: bold;
		border: 2px solid #2563eb;
		padding: 0.7rem 1.8rem;
		border-radius: 8px;
		transition: all 0.2s ease;
		background: transparent;
	}
	.materials-secondary-btn:hover {
		background: #2563eb;
		color: white;
	}

	/* --- SEO TEXT SECTION STYLING --- */
	.materials-seo-section {
		padding: 5rem 1.5rem;
		background-color: #ffffff;
		line-height: 1.8;
		color: #334155;
	}
	
	.materials-article-title {
		font-size: 2.1rem;
		color: #001f3f;
		text-align: center;
		margin-bottom: 3rem;
		font-weight: 800;
	}

	.materials-article-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		text-align: left;
	}

	.materials-article-text h3 {
		color: #2563eb;
		font-size: 1.3rem;
		margin-top: 1rem;
		margin-bottom: 0.75rem;
		font-weight: 700;
	}

	.materials-article-text p {
		margin-bottom: 1.5rem;
		font-size: 1rem;
	}

	.materials-seo-section strong {
		color: #0f172a;
	}

	/* --- CALL TO ACTION PANEL STYLING --- */
	.materials-cta-banner {
		margin-top: 4rem;
		background: #f1f5f9;
		padding: 3rem;
		border-radius: 15px;
		text-align: center;
		border: 2px dashed #cbd5e1;
	}

	.materials-cta-banner p {
		font-size: 1.05rem;
		font-weight: 500;
		margin-bottom: 1.2rem;
		color: #1e293b;
	}

	.materials-primary-btn {
		background: #001f3f;
		color: white;
		padding: 0.9rem 2.2rem;
		border-radius: 8px;
		text-decoration: none;
		font-weight: bold;
		display: inline-block;
		transition: background 0.2s ease;
	}

	.materials-primary-btn:hover {
		background: #2563eb;
	}

	/* --- RESPONSIVE SCREEN BREAKPOINTS --- */
	@media (max-width: 1024px) {
		.materials-grid-hub {
			grid-template-columns: repeat(2, 1fr);
		}
		.materials-article-grid {
			gap: 1.5rem;
		}
	}

	@media (max-width: 768px) {
		.materials-hero-container {
			min-height: 65vh;
		}
		.materials-hero-overlay {
			padding: 1.5rem;
		}
		.materials-section-title {
			font-size: 1.8rem;
		}
		.materials-article-grid {
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		.materials-article-title {
			font-size: 1.6rem;
			margin-bottom: 1.5rem;
		}
		.materials-cta-banner {
			padding: 2rem 1.2rem;
		}
	}

	@media (max-width: 640px) {
		.materials-grid-hub {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
		.materials-hub-card {
			max-width: 420px;
			margin: 0 auto;
		}
	}
</style>