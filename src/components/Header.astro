  }

  .intl-text {
    font-size: 0.55rem;
    font-weight: 600;
    color: #64748b;
    letter-spacing: 3.8px;
    margin-top: 2px;
    text-transform: uppercase;
  }

  .blue-text { color: #2563eb; }

  .logo {
    flex-shrink: 0;
    margin-right: 15px;
  }

  /* 4. DESKTOP BASE NAVIGATION */
  .search-wrapper { flex: 0 1 450px; margin: 0 1.5rem; }
  .nav-section { display: flex; align-items: center; }
  .nav-menu { display: flex; gap: 1.5rem; align-items: center; }
    
  .nav-link { 
    text-decoration: none; 
    color: #1e293b; 
    font-weight: 600; 
    font-size: 0.95rem;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
  }
  .nav-link.active { color: #dc2626; border-bottom: 2px solid #dc2626; padding-bottom: 2px; }
  .contact-btn { background: #001f3f; color: #fff; padding: 0.5rem 1.2rem; border-radius: 5px; text-decoration: none; font-weight: 600; }

  /* 5. MODERN DROPDOWN SYSTEM */
  .dropdown-wrapper {
    position: relative;
    display: inline-block;
  }

  .dropdown-caret {
    font-size: 0.55rem;
    color: #64748b;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Desktop View Styles */
  @media (min-width: 769px) {
    .dropdown-menu {
      opacity: 0;
      visibility: hidden;
      transform: translateY(10px);
      position: absolute;
      top: calc(100% + 15px); 
      left: 50%;
      transform: translateX(-50%) translateY(10px);
      background-color: #ffffff;
      min-width: 240px;
      max-height: 450px; /* Limits size cleanly with built-in scrollbar */
      overflow-y: auto;
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
      border-radius: 12px;
      padding: 0.6rem;
      z-index: 1100;
      border: 1px solid #f1f5f9;
      transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    }

    /* REMOVED :hover TRIGGER RULES SO CLICKING THE ARROW IS MANDATORY ON DESKTOP */
    .dropdown-wrapper.open .dropdown-menu {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }
    
    .dropdown-wrapper.open .dropdown-caret {
      transform: rotate(180deg);
      color: #dc2626;
    }

    .submenu-link {
      display: flex;
      align-items: center;
      padding: 0.7rem 1rem;
      color: #334155;
      text-decoration: none;
      font-weight: 550;
      font-size: 0.9rem;
      border-radius: 8px;
      transition: background 0.2s ease, color 0.2s ease;
    }

    .submenu-link:hover {
      background-color: #f8fafc;
      color: #059669; 
    }

    .submenu-link.sub-active {
      color: #dc2626;
      background-color: #fef2f2;
      font-weight: 600;
    }
  }

  /* 6. MOBILE RESPONSIVE DRAWERS & ACCORDION */
  .mobile-search-layer {
    background: #f8fafc;
    padding: 10px 20px;
    border-top: 1px solid #e2e8f0;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: space-around;
    width: 30px;
    height: 21px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .bar { width: 30px; height: 3px; background-color: #001f3f; border-radius: 10px; transition: 0.3s; }

  .desktop-only { display: block; }
  .mobile-only { display: none; }

  @media (max-width: 768px) {
    .desktop-only { display: none; }
    .mobile-only { display: flex; }
    .hamburger { display: flex; }

    .nav-menu {
      display: none;
      position: fixed;
      top: 135px;      
      left: 0;
      width: 100%;
      height: calc(100vh - 135px);
      background: white;
      flex-direction: column;
      padding: 1.5rem;
      box-shadow: 0 10px 15px rgba(0,0,0,0.1);
      overflow-y: auto;
      align-items: flex-start;
      gap: 0;
    }

    .nav-menu.active { display: flex; }
    
    .nav-link { 
      font-size: 1.15rem; 
      padding: 1rem 0; 
      width: 100%; 
      text-align: left;
    }

    .dropdown-menu {
      display: none; 
      width: 100%;
      padding-left: 1rem;
      background-color: #f8fafc;
      border-radius: 8px;
      margin-top: 0.25rem;
    }

    .dropdown-wrapper.open .dropdown-menu {
      display: block;
    }

    .dropdown-wrapper.open .dropdown-caret {
      transform: rotate(180deg);
    }

    .submenu-link {
      display: block;
      text-decoration: none;
      color: #475569;
      font-size: 1.05rem;
      padding: 0.8rem 0.5rem;
      width: 100%;
      border-bottom: 1px dashed #e2e8f0;
