}

.badge-number {
  display: block;
  font-size: 1.8rem;
  font-weight: 800;
  color: #059669;
}

.badge-label {
  font-size: 0.9rem;
  text-transform: uppercase;
  letter-spacing: 1px;
}

@media (max-width: 768px) {
  .trust-content {
    flex-direction: column;
    text-align: center;
  }
  .trust-badge-container {
    flex-direction: row;
    width: 100%; /* Ensure container fills width */
    gap: 10px;   /* Narrower gap for small screens */
  }
  /* --- ADD THIS PART BELOW --- */
  .badge {
    flex: 1;      /* Allows badges to shrink equally */
    min-width: 0; /* REMOVES the 180px restriction */
    padding: 10px;
    font-size: 0.8rem;
  }
  .badge-number {
    font-size: 1.4rem; /* Makes text fit better on mobile */
  }
}

.machinery-filter {
  background: #f9fafb;
  border-radius: 16px;
  padding: 25px;
  margin: 20px 0 40px;
  border: 1px solid #e5e7eb;
}

.filter-header h3 {
  font-size: 1.2rem;
  margin: 0;
  color: #001f3f;
}

.filter-header p {
  font-size: 0.9rem;
  color: #6b7280;
  margin-bottom: 15px;
}

/* And still hide the extra input */
.machinery-filter input[type="text"] {
  display: none !important;
}

/* SURGERY: Total disappearance of the second search bar */

/* 1. Target the Pagefind UI specifically if it's being injected into the filter section */
.machinery-filter .pagefind-ui,
.machinery-filter #search,
.price-filter-box .pagefind-ui,
.price-filter-box #search {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    pointer-events: none !important;
    height: 0 !important;
    margin: 0 !important;
}

/* 2. Target any rogue inputs that aren't the price slider */
.machinery-filter input:not([type="range"]) {
    display: none !important;
}

</style>