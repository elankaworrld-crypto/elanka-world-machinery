---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="About E Lanka World International | Premier Machinery Supplier Sri Lanka"
  description="Since 2002, E Lanka World International has provided elite packaging machinery, processing systems, and conveyor solutions to Sri Lanka's leading industries."
>
  <main class="about-container">
    
    <!-- Hero Section with SVG Pattern -->
    <section class="about-hero">
      <div class="hero-bg-pattern">
        <svg width="100%" height="100%" viewBox="0 0 100 100" preserveAspectRatio="none">
          <path d="M0 100 L100 0 L100 100 Z" fill="rgba(255,255,255,0.05)"></path>
        </svg>
      </div>
      <div class="content-wrapper hero-content">
        <span class="badge">Established 2002</span>
        <h1>Engineering Excellence for Sri Lankan Industry</h1>
        <p class="subtitle">From Atlas Lanka Trading to E Lanka World International—Two decades of powering production lines with world-class technology.</p>
      </div>
    </section>

    <!-- Visual Stats Bar -->
    <section class="trust-bar">
      <div class="stat-card">
        <div class="stat-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
        </div>
        <strong>22+ Years</strong>
        <span>Industrial Heritage</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-card">
        <div class="stat-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        </div>
        <strong>Official Agent</strong>
        <span>PACKONI & Zodpro</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-card">
        <div class="stat-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
        </div>
        <strong>100M+ LKR</strong>
        <span>Project Value</span>
      </div>
    </section>

    <!-- History / Timeline Section -->
    <section class="history-section">
      <div class="content-wrapper">
        <div class="grid-2">
          <div class="history-visual">
            <div class="timeline-box">
              <div class="timeline-item">
                <span class="year">2002</span>
                <p>Founded as <strong>Atlas Lanka Trading</strong>, focusing on core hardware and industrial tools.</p>
              </div>
              <div class="timeline-item active">
                <span class="year">2021</span>
                <p>Strategic rebranding to <strong>E Lanka World International</strong> with major infrastructure investment.</p>
              </div>
              <div class="timeline-item">
                <span class="year">Today</span>
                <p>The leading supplier for <strong>packaging machinery</strong> and <strong>conveyor solutions</strong> in Sri Lanka.</p>
              </div>
            </div>
          </div>
          <div class="history-text">
            <h2>Our Legacy of Trust</h2>
            <p>For over two decades, we have been the silent engine behind some of Sri Lanka’s most successful production facilities. What started as a focused hardware trade has evolved into a comprehensive machinery ecosystem.</p>
            <p>Recognizing the shift towards automation, we secured official distributorships for global giants <strong>PACKONI</strong> and <strong>Zodpro</strong>. This allows us to bring international processing standards directly to the local market with the "Atlas-born" reliability our clients have trusted since 2002.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid with Custom Icons -->
    <section class="expertise-section">
      <div class="content-wrapper">
        <h2 class="section-title">Specialized Industrial Solutions</h2>
        <div class="services-grid">
          <div class="glass-card">
            <div class="card-head">
              <svg viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
              <h3>Packaging Machinery</h3>
            </div>
            <p>Authorized PACKONI systems for high-speed liquid filling, pouch packing, and automated sealing lines.</p>
          </div>

          <div class="glass-card">
            <div class="card-head">
              <svg viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2"><path d="M4 9h16M4 15h16M10 3L8 21M16 3l-2 18"/></svg>
              <h3>Coding & Marking</h3>
            </div>
            <p>Official Zodpro inkjet and laser solutions for batch coding, MRP printing, and product traceability.</p>
          </div>

          <div class="glass-card">
            <div class="card-head">
              <svg viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2"><path d="M7 11l5 5 5-5M7 7l5 5 5-5"/></svg>
              <h3>Material Handling</h3>
            </div>
            <p>Custom-engineered conveyor systems, freight elevators, and industrial material flow automation.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- WhatsApp CTA -->
    <section class="cta-section">
      <div class="content-wrapper">
        <div class="cta-card">
          <h2>Ready to Upgrade Your Production?</h2>
          <p>Get a technical consultation and a customized quote for your machinery needs.</p>
          <div class="cta-btns">
             <a href="/shop" class="btn-secondary">View Catalog</a>
             <a href="https://wa.me/94776344758?text=Hello%20E%20Lanka%20World%20learnt%20about%20you%20on%20the%20web%20give%20me%20more%20details" class="btn-whatsapp-modern">
               <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.438 9.889-9.886.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981z"/></svg>
               Consult an Expert
             </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  :root {
    --primary: #001f3f;
    --accent: #2563eb;
    --text: #1e293b;
    --light: #f8fafc;
  }

  .about-container { color: var(--text); overflow-x: hidden; }
  .content-wrapper { max-width: 1100px; margin: 0 auto; padding: 0 20px; }

  /* Hero Section */
  .about-hero { 
    background: var(--primary); 
    color: white; 
    padding: 100px 0; 
    position: relative; 
    text-align: center;
  }
  .hero-bg-pattern { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; }
  .badge { background: var(--accent); padding: 5px 15px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; text-transform: uppercase; margin-bottom: 20px; display: inline-block; }
  .about-hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.1; margin-bottom: 20px; }
  .subtitle { font-size: 1.2rem; max-width: 700px; margin: 0 auto; opacity: 0.9; }

  /* Trust Bar */
  .trust-bar { 
    display: flex; 
    justify-content: space-around; 
    align-items: center; 
    background: white; 
    padding: 40px 20px; 
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    margin-top: -40px;
    border-radius: 10px;
    position: relative;
    z-index: 10;
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
  }
  .stat-card { text-align: center; display: flex; flex-direction: column; align-items: center; }
  .stat-icon { color: var(--accent); margin-bottom: 10px; }
  .stat-card strong { font-size: 1.5rem; color: var(--primary); }
  .stat-card span { font-size: 0.8rem; color: #64748b; font-weight: 600; }
  .stat-divider { width: 1px; height: 50px; background: #e2e8f0; }

  /* History Grid */
  .history-section { padding: 100px 0; }
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .timeline-box { border-left: 3px solid #e2e8f0; padding-left: 30px; }
  .timeline-item { position: relative; margin-bottom: 40px; opacity: 0.7; }
  .timeline-item.active { opacity: 1; }
  .timeline-item::before { 
    content: ''; position: absolute; left: -38.5px; top: 5px; 
    width: 14px; height: 14px; border-radius: 50%; background: #cbd5e1; border: 3px solid white;
  }
  .timeline-item.active::before { background: var(--accent); transform: scale(1.3); }
  .year { display: block; font-weight: 900; color: var(--accent); font-size: 1.2rem; margin-bottom: 5px; }

  /* Expertise Cards */
  .expertise-section { background: var(--light); padding: 100px 0; }
  .section-title { text-align: center; margin-bottom: 50px; }
  .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }
  .glass-card { 
    background: white; padding: 40px; border-radius: 15px; 
    border: 1px solid #e2e8f0; transition: 0.3s;
  }
  .glass-card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.05); }
  .card-head { display: flex; align-items: center; gap: 15px; margin-bottom: 20px; }
  .card-head svg { width: 40px; height: 40px; }
  .card-head h3 { margin: 0; font-size: 1.3rem; }

  /* CTA Modern */
  .cta-section { padding: 80px 0; }
  .cta-card { 
    background: var(--primary); color: white; padding: 60px; 
    border-radius: 20px; text-align: center;
    background-image: linear-gradient(45deg, #001f3f 0%, #003366 100%);
  }
  .cta-btns { display: flex; gap: 20px; justify-content: center; margin-top: 30px; }
  .btn-whatsapp-modern { 
    background: #25d366; color: white; padding: 15px 35px; 
    border-radius: 50px; text-decoration: none; font-weight: bold;
    display: flex; align-items: center; gap: 10px; transition: 0.3s;
  }
  .btn-secondary { 
    background: transparent; border: 2px solid white; color: white; 
    padding: 15px 35px; border-radius: 50px; text-decoration: none; font-weight: bold;
  }
  .btn-whatsapp-modern:hover { background: #128c7e; transform: translateY(-2px); }

  @media (max-width: 768px) {
    .grid-2 { grid-template-columns: 1fr; }
    .trust-bar { flex-direction: column; gap: 30px; margin-top: -20px; }
    .stat-divider { display: none; }
    .cta-btns { flex-direction: column; }
    .cta-card { padding: 40px 20px; }
  }
</style>