---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Conveyor System Accessories & Spares Sri Lanka | E Lanka World">
	
	<main>
		<nav class="acc-breadcrumb">
			<div class="acc-container">
				<div class="acc-crumbs">
					<a href="/">Home</a>
					<span>&gt;</span>
					<a href="/shop">Shop</a>
					<span>&gt;</span>
					<a href="/conveyor">Conveyor Systems</a>
					<span>&gt;</span>
					<span class="acc-current">Accessories & Spares</span>
				</div>
			</div>
		</nav>

		<section class="acc-hero">
			<div class="acc-container">
				<div class="acc-hero-content">
					<h1>Conveyor System Accessories in Sri Lanka</h1>
					<p>Keep your factory lines operating at peak capacity. We supply a comprehensive inventory of heavy-duty replacement parts, custom drive motors, and professional support services tailored for Sri Lankan industrial setups.</p>
					<a href="https://wa.me/94776344758" class="acc-whatsapp-btn">Inquire via WhatsApp</a>
				</div>
			</div>
		</section>

		<section class="acc-grid-section">
			<div class="acc-container">
				<h2 class="acc-section-title">Our Material Handling Sub-Categories</h2>
				<p class="acc-section-subtitle">High-durability spare components sourced from trusted international manufacturers to minimize factory downtime.</p>
				
				<div class="acc-grid">
					
					<article class="acc-card">
						<div class="acc-img-wrapper">
							<img 
								src="/products/conveyor-belts-supplies-sri-lanka.webp" 
								alt="Premium replacement conveyor belts including PVC, PU, and modular interlocking plastic mesh" 
								width="1200"
								height="675"
								loading="eager"
								decoding="async"
							/>
						</div>
						<div class="acc-card-body">
							<h3>Conveyor Belts (Spares)</h3>
							<p>Industrial tracker bands available in flat PVC, food-grade PU, heat-resistant variants, rough-top gripping structures, and interlocking modular plastic mesh built to your exact layout length and width specifications.</p>
							<a href="/conveyor-belts-only" class="acc-card-cta">Order Custom Belt &rarr;</a>
						</div>
					</article>

					<article class="acc-card">
						<div class="acc-img-wrapper">
							<img 
								src="/products/industrial-conveyor-motors-gearbox.webp" 
								alt="Heavy-duty industrial conveyor electric motors and speed reduction gearboxes" 
								width="1200"
								height="675"
								loading="lazy"
								decoding="async"
							/>
						</div>
						<div class="acc-card-body">
							<h3>Conveyor Motors & Drives</h3>
							<p>High-torque induction motors combined with precision worm gear speed reducers. Fully compatible with digital variable frequency drives (VFD) for adjustable conveyor line synchronization.</p>
							<a href="https://wa.me/94776344758" class="acc-card-cta">Get Motor Specs &rarr;</a>
						</div>
					</article>

					<article class="acc-card">
						<div class="acc-img-wrapper">
							<img 
								src="/products/heavy-duty-conveyor-rollers-idlers.webp" 
								alt="Stainless steel and zinc-plated driven and gravity conveyor rollers" 
								width="1200"
								height="675"
								loading="lazy"
								decoding="async"
							/>
						</div>
						<div class="acc-card-body">
							<h3>Conveyor Rollers & Idlers</h3>
							<p>Precision-engineered gravity rollers, driven rollers, tapered curve components, and impact idlers constructed from heavy-wall stainless steel or galvanized steel with smooth internal dust-proof bearings.</p>
							<a href="https://wa.me/94776344758" class="acc-card-cta">Request Roller Sizes &rarr;</a>
						</div>
					</article>

					<article class="acc-card">
						<div class="acc-img-wrapper">
							<img 
								src="/products/conveyor-belt-vulcanizing-service.webp" 
								alt="Professional hot and cold joint conveyor belt vulcanizing service by E Lanka World International" 
								width="1200"
								height="675"
								loading="lazy"
								decoding="async"
							/>
						</div>
						<div class="acc-card-body">
							<h3>Conveyor Belt Vulcanizing Services</h3>
							<p>On-site high-strength belt splicing, seamless hot vulcanizing joint processing, cold adhesive splicing, and tracking alignment assessments executed by our experienced technical repair team.</p>
							<a href="https://wa.me/94776344758" class="acc-card-cta">Book Service Team &rarr;</a>
						</div>
					</article>

				</div>
			</div>
		</section>

		<section class="acc-trust-article">
			<div class="acc-container">
				<h2>Why Source Conveyor Components From E Lanka World?</h2>
				<div class="acc-article-grid">
					<div>
						<h3>Immediate Inventory Availability</h3>
						<p>Production line stoppages cost your business money every hour. We maintain a dependable, ready stock of structural conveyor components, electrical accessories, and wear-and-tear tracker strips right here in Sri Lanka to ensure quick turnaround times.</p>
					</div>
					<div>
						<h3>Technical Maintenance Commitment</h3>
						<p>True to our enterprise philosophy, <strong>"We sell only what we can repair."</strong> Our service doesn't end with delivery. We provide deep technical setup alignment assistance to make sure your newly fitted accessories integrate perfectly with your packaging machinery.</p>
					</div>
				</div>
				<div class="acc-bottom-nav">
					<a href="/conveyor" class="acc-secondary-btn">&larr; Return to Conveyor Systems Main Hub</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	/* --- LAYOUT UTILITIES --- */
	.acc-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	/* --- BREADCRUMB --- */
	.acc-breadcrumb {
		background-color: #f8fafc;
		border-bottom: 1px solid #e2e8f0;
		padding: 0.75rem 0;
	}
	.acc-crumbs {
		display: flex;
		gap: 0.75rem;
		font-size: 0.9rem;
		font-weight: 500;
		color: #64748b;
	}
	.acc-crumbs a {
		color: #2563eb;
		text-decoration: none;
	}
	.acc-crumbs a:hover {
		text-decoration: underline;
	}
	.acc-current {
		color: #1e293b;
		pointer-events: none;
	}

	/* --- HERO SECTION --- */
	.acc-hero {
		background: linear-gradient(135deg, #001f3f 0%, #0b3c5d 100%);
		color: #ffffff;
		padding: 5rem 0;
		text-align: center;
	}
	.acc-hero-content {
		max-width: 800px;
		margin: 0 auto;
	}
	.acc-hero h1 {
		font-size: clamp(2rem, 5vw, 2.8rem);
		font-weight: 800;
		line-height: 1.2;
		margin-bottom: 1.2rem;
		color: #ffffff;
	}
	.acc-hero p {
		font-size: 1.1rem;
		line-height: 1.7;
		color: #cbd5e1;
		margin-bottom: 2rem;
	}
	.acc-whatsapp-btn {
		background: #25D366;
		color: white;
		padding: 0.9rem 2.2rem;
		border-radius: 50px;
		text-decoration: none;
		font-weight: bold;
		display: inline-block;
		transition: transform 0.2s;
		box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
	}
	.acc-whatsapp-btn:hover {
		transform: scale(1.03);
	}

	/* --- GRID SECTION --- */
	.acc-grid-section {
		padding: 5rem 0;
		background-color: #f8fafc;
		text-align: center;
	}
	.acc-section-title {
		font-size: 2.2rem;
		color: #001f3f;
		font-weight: 800;
		margin-bottom: 0.75rem;
	}
	.acc-section-subtitle {
		color: #64748b;
		font-size: 1.05rem;
		max-width: 650px;
		margin: 0 auto 4rem auto;
	}
	.acc-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr); /* Clean 2x2 symmetry block grid */
		gap: 2.5rem;
		text-align: left;
	}
	.acc-card {
		background: #ffffff;
		border-radius: 12px;
		box-shadow: 0 4px 20px rgba(0,0,0,0.04);
		border-top: 5px solid #2563eb;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		transition: transform 0.25s ease;
	}
	.acc-card:hover {
		transform: translateY(-4px);
	}
	.acc-img-wrapper {
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background-color: #e2e8f0;
	}
	.acc-img-wrapper img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.acc-card-body {
		padding: 2rem;
		display: flex;
		flex-direction: column;
		flex-grow: 1;
	}
	.acc-card-body h3 {
		color: #001f3f;
		font-size: 1.35rem;
		margin-bottom: 0.75rem;
		font-weight: 700;
		border-bottom: 2px solid #f1f5f9;
		padding-bottom: 0.5rem;
	}
	.acc-card-body p {
		color: #475569;
		font-size: 0.98rem;
		line-height: 1.6;
		margin-bottom: 1.5rem;
		flex-grow: 1;
	}
	.acc-card-cta {
		color: #2563eb;
		text-decoration: none;
		font-weight: 700;
		font-size: 0.95rem;
	}
	.acc-card-cta:hover {
		text-decoration: underline;
	}

	/* --- TRUST TEXT SECTION --- */
	.acc-trust-article {
		padding: 5rem 0;
		background-color: #ffffff;
		color: #334155;
	}
	.acc-trust-article h2 {
		font-size: 2rem;
		color: #001f3f;
		text-align: center;
		margin-bottom: 3rem;
		font-weight: 800;
	}
	.acc-article-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		margin-bottom: 4rem;
	}
	.acc-article-grid h3 {
		color: #2563eb;
		font-size: 1.3rem;
		margin-bottom: 0.75rem;
		font-weight: 700;
	}
	.acc-article-grid p {
		line-height: 1.7;
		font-size: 1rem;
	}
	.acc-bottom-nav {
		text-align: center;
	}
	.acc-secondary-btn {
		display: inline-block;
		color: #2563eb;
		text-decoration: none;
		font-weight: bold;
		border: 2px solid #2563eb;
		padding: 0.7rem 1.8rem;
		border-radius: 8px;
		transition: all 0.2s ease;
	}
	.acc-secondary-btn:hover {
		background: #2563eb;
		color: white;
	}

	/* --- SCREEN BREAKPOINTS --- */
	@media (max-width: 768px) {
		.acc-grid {
			grid-template-columns: 1fr; /* Drop cleanly down into single card stacks for crisp smartphone renders */
			gap: 1.5rem;
		}
		.acc-article-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
		.acc-trust-article h2 {
			font-size: 1.6rem;
		}
		.acc-section-title {
			font-size: 1.8rem;
		}
	}
</style>