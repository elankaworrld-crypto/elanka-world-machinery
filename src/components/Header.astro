<link href="/_pagefind/pagefind-ui.css" rel="stylesheet">
<script src="/_pagefind/pagefind-ui.js" is:inline></script>

<script is:inline>
  function initSearch() {
    setTimeout(() => {
      if (typeof PagefindUI !== 'undefined') {
        new PagefindUI({ 
            element: "#search", 
            showSubResults: true,
            translations: { placeholder: "Search machinery..." } 
        });
        new PagefindUI({ 
            element: "#search-mobile", 
            showSubResults: true,
            translations: { placeholder: "Search..." } 
        });
      }
    }, 500); 
  }
  
  window.addEventListener('load', initSearch);

  // HAMBURGER LOGIC
  const hamburger = document.getElementById('hamburgerBtn');
  const navMenu = document.getElementById('navMenu');

  hamburger?.addEventListener('click', () => {
      hamburger.classList.toggle('active');
      navMenu.classList.toggle('active');
  });

  // UNIVERSAL INTERACTIVE ENGINE FOR MULTIPLE DROPDOWNS
  const dropdowns = [
    { id: 'shopDropdown', path: '/shop' },
    { id: 'conveyorDropdown', path: '/conveyor' }
  ];

  dropdowns.forEach(({ id }) => {
    const wrapper = document.getElementById(id);
    const arrowBtn = wrapper?.querySelector('.dropdown-arrow-btn');

    arrowBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();

      const isOpen = wrapper.classList.contains('open');

      // Close all other open dropdowns first
      dropdowns.forEach(d => {
        if (d.id !== id) {
          const otherWrapper = document.getElementById(d.id);
          otherWrapper?.classList.remove('open');
          otherWrapper?.querySelector('.dropdown-arrow-btn')?.setAttribute('aria-expanded', 'false');
        }
      });
      
      // Toggle the targeted one
      if (isOpen) {
        wrapper.classList.remove('open');
        arrowBtn.setAttribute('aria-expanded', 'false');
      } else {
        wrapper.classList.add('open');
        arrowBtn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Global document click closer (Closes menus if clicking anywhere outside)
  document.addEventListener('click', (e) => {
    dropdowns.forEach(({ id }) => {
      const wrapper = document.getElementById(id);
      if (!wrapper?.contains(e.target)) {
        wrapper?.classList.remove('open');
        wrapper?.querySelector('.dropdown-arrow-btn')?.setAttribute('aria-expanded', 'false');
      }
    });
  });

  // Pagefind UI clear panel actions
  document.addEventListener('click', (e) => {
    const drawer = e.target.closest('.pagefind-ui__drawer');
    if (drawer) {
      const rect = drawer.getBoundingClientRect();
      const clickX = e.clientX - rect.left;
      const clickY = e.clientY - rect.top;

      if (clickX > (rect.width - 50) && clickY < 50) {
        const allInputs = document.querySelectorAll('.pagefind-ui__search-input');
        allInputs.forEach(input => {
          input.value = '';
          input.dispatchEvent(new Event('input', { bubbles: true }));
        });
        const allClears = document.querySelectorAll('.pagefind-ui__search-clear');
        allClears.forEach(clear => clear.click());
      }
    }
  });
</script>

<style is:global>
  /* 1. GLOBAL LAYOUT SETUP */
  body {
    padding-top: 80px;
  }

  @media (max-width: 768px) {
    body {
