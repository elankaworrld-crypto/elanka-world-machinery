---
import Layout from '../layouts/Layout.astro';

// SEO & Product Frontmatter Variables
const title = "Custom Production Lines & Automated Factory Solutions";
const shortDescription = "Tailor-made industrial automation and custom production lines in Sri Lanka. High-efficiency inclined Z-cleat elevators, hopper feeding units, and automated sorting tables.";
const description = "Design high-performance custom production lines in Sri Lanka. Fully integrated factory automation including Z-cleat elevators, raw hopper feeders, and custom packaging corridors.";
const brand = "E Lanka World International";
const image = "/products/custom-automated-production-line-sri-lanka.webp";
const images = [
  "/products/custom-automated-production-line-sri-lanka.webp",
  "/products/inclined-z-cleat-elevator-conveyor-system.webp"
];
const categories = ["Custom Production Lines", "Industrial Automation", "Packaging Machinery", "Material Handling Equipment"];
const features = [
  "High-efficiency inclined Z-cleat elevator conveyors",
  "Automated bulk hopper feeding and dosing systems",
  "Specialized collection sorting tables and packaging conveyors",
  "Fully synchronized integration with filling, capping, and sealing modules"
];
---

<Layout title={`${title} | E Lanka World`}>
  <main>
    <nav class="acc-breadcrumb">
      <div class="acc-container">
        <div class="acc-crumbs">
          <a href="/">Home</a>
          <span>&gt;</span>
          <a href="/shop">Shop</a>
          <span>&gt;</span>
          <a href="/automation">Automation</a>
          <span>&gt;</span>
          <span class="acc-current">Custom Production Lines</span>
        </div>
      </div>
    </nav>

    <section class="acc-hero">
      <div class="acc-container">
        <div class="acc-hero-content">
          <h1>{title}</h1>
          <p>{shortDescription}</p>
          <div style="margin-bottom: 1.5rem;">
            <a href="https://wa.me/94776344758" class="acc-whatsapp-btn">Inquire via WhatsApp for Custom Quotes</a>
          </div>
        </div>
      </div>
    </section>

    <section class="acc-grid-section" style="background-color: #ffffff; text-align: left;">
      <div class="acc-container">
    

        <p style="line-height: 1.7; color: #334155; margin-bottom: 1.5rem;">
          To compete in modern manufacturing, upgrading to synchronized automated layouts is vital. Our <strong>custom production lines</strong> are custom-engineered to link separate machinery units into a single seamless workflow. By removing manual handling checkpoints between raw processing and final shipping, these installations eliminate throughput bottlenecks and optimize plant output.
        </p>
        <p style="line-height: 1.7; color: #334155; margin-bottom: 2rem;">
          Whether you run a food processing warehouse, pharmaceutical lab, or industrial chemical site, we design and install high-efficiency inclined Z-cleat elevators, automated bulk hopper feeding units, and specialized collection sorting setups perfectly synchronized with automatic filling, capping, or film sealing modules.
        </p>

        <div style="background: #f0f9ff; border-radius: 6px; padding: 6px 15px; display: inline-block; border: 1px solid #0ea5e9; margin-bottom: 30px;">
          <span style="color: #0369a1; font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">Brand: {brand}</span>
        </div>

        <h3 style="color: #001f3f; font-size: 1.5rem; margin-bottom: 1rem; font-weight: 700;">Core System Features</h3>
        <ul style="margin-bottom: 3rem; padding-left: 20px; color: #334155; line-height: 1.8;">
          {features.map((feature) => (
            <li>{feature}</li>
          ))}
        </ul>

        <h3 style="color: #001f3f; font-size: 1.75rem; margin-bottom: 1rem; font-weight: 700;">Custom Material Handling & Processing Modules</h3>
        <p style="line-height: 1.7; color: #475569; margin-bottom: 2rem;">
          We specialize in integrating high-precision structural elements tailored specifically to your factory floor layout constraints and production metrics:
        </p>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 3rem;">
          <div style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #2563eb;">
            <h4 style="color: #2563eb; font-weight: 700; margin-bottom: 0.5rem;">Inclined Z-Cleat Elevators</h4>
            <p style="font-size: 0.95rem; line-height: 1.6; color: #475569;">Perfect for vertical elevation transfers. The cleated profiles securely lift granular food items, powders, small boxes, or components up to high-level packing, weighing, or pouch-filling nozzles without spillage.</p>
          </div>
          <div style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #2563eb;">
            <h4 style="color: #2563eb; font-weight: 700; margin-bottom: 0.5rem;">Automated Hopper Feeding Systems</h4>
            <p style="font-size: 0.95rem; line-height: 1.6; color: #475569;">Heavy-duty bulk storage bins paired with vibration feeders or screw conveyors. These units provide uniform raw material distribution directly to your automated processing lines without manual monitoring errors.</p>
          </div>
          <div style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #2563eb;">
            <h4 style="color: #2563eb; font-weight: 700; margin-bottom: 0.5rem;">Specialized Collection & Sorting Setups</h4>
            <p style="font-size: 0.95rem; line-height: 1.6; color: #475569;">Configured terminal accumulation hubs or multi-track line splitters. These tables collect filled bottles or bags, allowing operators to rapidly sort, batch, pack, or inspect outputs cleanly.</p>
          </div>
          <div style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #2563eb;">
            <h4 style="color: #2563eb; font-weight: 700; margin-bottom: 0.5rem;">Synchronized Line Corridors</h4>
            <p style="font-size: 0.95rem; line-height: 1.6; color: #475569;">Central control setups featuring variable speed matching. This links automated loaders, nitrogen band sealers, and date coding printers together so that products flow without piling up or stalling.</p>
          </div>
        </div>

        <h3 style="color: #001f3f; font-size: 1.5rem; margin-bottom: 1.5rem; font-weight: 700;">System Image Gallery</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 3rem;">
          {images.map((imgUrl, index) => (
            <div style="overflow: hidden; border-radius: 6px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
              <img 
                src={imgUrl} 
                alt={`Custom Production Assembly View ${index + 1}`} 
                style="width: 100%; height: auto; display: block; object-fit: cover;" 
              />
            </div>
          ))}
        </div>

        <h3 style="color: #001f3f; font-size: 1.75rem; margin-bottom: 1.5rem; font-weight: 700;">Integration Capabilities</h3>
        <table style="width: 100%; border-collapse: collapse; margin-bottom: 3rem; font-size: 0.95rem;">
          <thead>
            <tr style="background-color: #001f3f; color: white; text-align: left;">
              <th style="padding: 12px; border: 1px solid #cbd5e1;">Module Element</th>
              <th style="padding: 12px; border: 1px solid #cbd5e1;">Engineering Options & Specifications</th>
            </tr>
          </thead>
          <tbody>
            <tr style="background-color: #f8fafc;">
              <td style="padding: 12px; border: 1px solid #cbd5e1;"><strong>Elevator Options</strong></td>
              <td style="padding: 12px; border: 1px solid #cbd5e1;">Z-Type, Bucket Elevators, Incline Cleated Belts (Food-grade PU/PVC)</td>
            </tr>
            <tr>
              <td style="padding: 12px; border: 1px solid #cbd5e1;"><strong>Feeding Mechanics</strong></td>
              <td style="padding: 12px; border: 1px solid #cbd5e1;">Vibratory Feeders, Custom Screw Augers, Volumetric Hoppers</td>
            </tr>
            <tr style="background-color: #f8fafc;">
              <td style="padding: 12px; border: 1px solid #cbd5e1;"><strong>Chassis Engineering</strong></td>
              <td style="padding: 12px; border: 1px solid #cbd5e1;">Heavy-duty SUS304 Stainless Steel (Washdown proof)</td>
            </tr>
            <tr>
              <td style="padding: 12px; border: 1px solid #cbd5e1;"><strong>Control Panels</strong></td>
              <td style="padding: 12px; border: 1px solid #cbd5e1;">Central PLC System with Variable Frequency Drive (VFD) speed matching</td>
            </tr>
            <tr style="background-color: #f8fafc;">
              <td style="padding: 12px; border: 1px solid #cbd5e1;"><strong>Synchronization</strong></td>
              <td style="padding: 12px; border: 1px solid #cbd5e1;">Photoelectric sensor arrays linking filling heads, cappers, and labelers</td>
            </tr>
            <tr>
              <td style="padding: 12px; border: 1px solid #cbd5e1;"><strong>Power Standard</strong></td>
              <td style="padding: 12px; border: 1px solid #cbd5e1;">220V/380V Industrial Multi-Phase Standard matching local grids</td>
            </tr>
          </tbody>
        </table>

        <h3 style="color: #001f3f; font-size: 1.75rem; margin-bottom: 1rem; font-weight: 700;">Tailor-Made Industrial Solutions for Sri Lankan Factories</h3>
        <p style="line-height: 1.7; color: #334155; margin-bottom: 1.5rem;">
          When investing in specialized factory frameworks, true value relies on exact material alignment and technical layout integration. Standard off-the-shelf conveyors often leave gaps, leading to tipped bottles, product tracking failures, or uneven hopper feeds. Our layouts are mapped out to remove structural height gaps and sync flawlessly with processing modules.
        </p>
        <p style="line-height: 1.7; color: #334155; margin-bottom: 3rem;">
          Built completely with rugged SUS304 stainless steel structures, these custom corridors handle high-humidity processing environments, intensive washdowns, and continuous operational runtime cycles without losing tracking integrity.
        </p>
        
      </div>
    </section>

    <section class="acc-trust-article" style="background-color: #f8fafc;">
      <div class="acc-container">
        <h2>Why Choose E Lanka World International for Factory Automation?</h2>
        <div class="acc-article-grid">
          <div>
            <h3>Expert Local Engineering Mapping</h3>
            <p>Every facility layout is distinct. Our team works closely with you to design, measure, and assemble the optimal combination of incline elevators, storage hoppers, and transfer beds to fit your production goals and space perfectly.</p>
          </div>
          <div>
            <h3>Dedicated Lifetime Technical Assurance</h3>
            <p>We build our service footprint on a simple rule: <strong>\"We sell only what we can repair.\"</strong> From custom programming adjustments to keeping a full local inventory of replacement tracks, belts, and motors, your uptime remains our priority.</p>
          </div>
        </div>
        <div class="acc-bottom-nav">
          <a href="/shop" class="acc-secondary-btn">&larr; Return to Main Machinery Shop</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .acc-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .acc-breadcrumb {
    background-color: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
    padding: 0.75rem 0;
  }
  .acc-crumbs {
    display: flex;
    gap: 0.75rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: #64748b;
  }
  .acc-crumbs a {
    color: #2563eb;
    text-decoration: none;
  }
  .acc-crumbs a:hover {
    text-decoration: underline;
  }
  .acc-current {
    color: #1e293b;
    pointer-events: none;
  }
  .acc-hero {
    background: linear-gradient(135deg, #001f3f 0%, #0b3c5d 100%);
    color: #ffffff;
    padding: 5rem 0;
    text-align: center;
  }
  .acc-hero-content {
    max-width: 800px;
    margin: 0 auto;
  }
  .acc-hero h1 {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1.2rem;
  }
  .acc-hero p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #cbd5e1;
    margin-bottom: 2rem;
  }
  .acc-whatsapp-btn {
    background: #25D366;
    color: white;
    padding: 0.9rem 2.2rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: bold;
    display: inline-block;
    transition: transform 0.2s;
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
  }
  .acc-whatsapp-btn:hover {
    transform: scale(1.03);
  }
  .acc-grid-section {
    padding: 5rem 0;
  }
  .acc-trust-article {
    padding: 5rem 0;
  }
  .acc-article-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }
  .acc-article-grid h3 {
    color: #2563eb;
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
  }
  .acc-article-grid p {
    line-height: 1.7;
    font-size: 1rem;
  }
  .acc-bottom-nav {
    text-align: center;
  }
  .acc-secondary-btn {
    display: inline-block;
    color: #2563eb;
    text-decoration: none;
    font-weight: bold;
    border: 2px solid #2563eb;
    padding: 0.7rem 1.8rem;
    border-radius: 8px;
    transition: all 0.2s ease;
  }
  .acc-secondary-btn:hover {
    background: #2563eb;
    color: white;
  }
  @media (max-width: 768px) {
    .acc-article-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>