}

.btn-about:hover {
  background: #047857;
}

/* Trust Badges */
.trust-badge-container {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.badge {
  background: rgba(255, 255, 255, 0.1);
  padding: 20px;
  border-radius: 12px;
