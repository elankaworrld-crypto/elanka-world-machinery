---
import Layout from '../../layouts/Layout.astro';
import PriceFilter from '../../components/PriceFilter.jsx';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allProducts = await getCollection('products');

  // This defines the missing variable by pulling unique categories from your products
  const uniqueCategories = [
    ...new Set(allProducts.flatMap((item) => item.data.categories || []))
  ];

  return uniqueCategories.map(cat => {
    const slug = cat.toLowerCase().trim().replace(/\s+/g, '-');
    const filteredProducts = allProducts.filter(item => 
      item.data.categories && item.data.categories.includes(cat)
    );
    
    return {
      params: { category: slug },
      props: { 
        categoryName: cat, 
        products: filteredProducts,
        allCategories: uniqueCategories 
      },
    };
  });
}
const { categoryName, products, allCategories = [] } = Astro.props;

const seoTitle = `${categoryName} in Sri Lanka | E Lanka World`;
const seoDescription = `Best ${categoryName} in Sri Lanka. E Lanka World provides high-performance ${categoryName} with local warranty, island-wide delivery, and expert technical support.`;

const facebookUrl = "https://www.facebook.com/CodingMachineSriLanka/";
const youtubeUrl = "https://www.youtube.com/@atlaslanka2116";

// This is truly universal. It works for 1 or 1,000 categories.
const currentContent = {
  guide: `High-performance ${categoryName} solutions are critical for maintaining production standards in the Sri Lankan industrial sector. Our range of ${categoryName} is specifically selected to provide durability, precision, and ease of use for local manufacturers, from small-scale startups to large factories.`,
  
  faq: [
    { 
      q: `Do you provide technical support for ${categoryName} in Sri Lanka?`, 
      a: `Yes, we offer full technical support, installation, and operator training for every ${categoryName} we supply. Our service team covers Colombo, Gampaha, and all major industrial zones.` 
    },
    { 
      q: `What are the power requirements for this ${categoryName}?`, 
      a: `Most of our ${categoryName} units are designed for standard Sri Lankan 230V single-phase power, making them easy to integrate into your existing production line.` 
    },
    { 
      q: `Are spare parts available for ${categoryName}?`, 
      a: `We maintain a comprehensive stock of essential spare parts and consumables for all ${categoryName} models to ensure your production never stops.` 
    }
  ]
};
---


<Layout title={seoTitle} description={seoDescription}>

<script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `${categoryName} - Industrial Machinery Sri Lanka`,
    "description": seoDescription,
    "publisher": {
      "@type": "Organization",
      "name": "E Lanka World International",
      "areaServed": "Sri Lanka"

    }
  })} />

  <main class="category-page">
    <div class="container">
      
      <nav class="breadcrumbs">
        <a href="/">Home</a> <span>/</span> 
        <a href="/shop">Shop</a> <span>/</span> 
        <span class="current">{categoryName}</span>
      </nav>

      <header class="cat-header">
        <h1>{categoryName} in Sri Lanka</h1>
        <p class="intro-text">
          Maximize your production efficiency with our professional <strong>{categoryName}</strong>. 
          At E Lanka World International, we supply high-precision equipment designed for the evolving 
          Sri Lankan manufacturing sector.
        </p>

        <div class="social-proof">
  <a 
    href={facebookUrl} 
    target="_blank" 
    class="soc-btn fb" 
    aria-label={`Follow E Lanka World on Facebook for ${categoryName} updates`}
  >
    Facebook Page
  </a>
  <a 
    href={youtubeUrl} 
    target="_blank" 
    class="soc-btn yt" 
    aria-label={`Watch ${categoryName} demonstration videos on YouTube`}
  >
    Watch Demos
  </a>
</div>
      </header>


<section class="machinery-filter">
  <div class="filter-header">
    <h3>Filter {categoryName} by Budget</h3>
    <p>Use the slider below to find the right industrial solution for your price range.</p>
  </div>
  <PriceFilter client:load initialProducts={products} categoryName={categoryName} />
</section>

    <section class="seo-guide">
  <h2>The Ultimate Guide to {categoryName} in Sri Lanka</h2>
  <div class="guide-content">
    <p>{currentContent.guide}</p>
    <p>At E Lanka World International, we understand the local market requirements for <strong>{categoryName}</strong>, ensuring all equipment meets industrial safety and efficiency standards.</p>
  </div>
</section>

<section class="faq-section">
  <h2>{categoryName} Frequently Asked Questions</h2>
  <div class="faq-grid">
    {currentContent.faq.map(item => (
      <div class="faq-item">
        <p class="faq-q"><strong>{item.q}</strong></p>
        <p class="faq-a">{item.a}</p>
      </div>
    ))}
  </div>
</section>

      <section class="trust-block">
  <h2>Why Source {categoryName} From Us?</h2>
  <div class="trust-grid">
    <div class="trust-card">
      <h4>Local Sri Lankan Warranty</h4>
      <p>We provide full technical support and spare parts for {categoryName} across Colombo, Kandy, and Gampaha.</p>
    </div>
    <div class="trust-card">
      <h4>Fast Island-wide Shipping</h4>
      <p>Get your {categoryName} delivered safely to your factory anywhere in Sri Lanka within 2-4 business days.</p>
    </div>
  </div>
</section>

    </div>

    <section class="company-trust-footer">
  <div class="trust-content">
    <div class="trust-text">
      <h2>About E Lanka World International</h2>
      <p>
        Since our inception, <strong>E Lanka World International</strong> has been a cornerstone in the Sri Lankan manufacturing landscape. 
        We specialize in importing high-performance industrial packaging and coding machinery directly from top-tier manufacturers.
      </p>
      <ul class="trust-points">
        <li>✅ <strong>Direct Importer:</strong> No middle-men, ensuring the best prices in Sri Lanka.</li>
        <li>✅ <strong>Expert Technical Team:</strong> On-site installation and maintenance support.</li>
        <li>✅ <strong>Ready Stock:</strong> We maintain a local warehouse for quick delivery and spare parts.</li>
      </ul>
      <a href="/about" class="btn-about">Learn More About Our Journey</a>
    </div>
    <div class="trust-badge-container">
      <div class="badge">
        <span class="badge-number">100%</span>
        <span class="badge-label">Genuine Parts</span>
      </div>
      <div class="badge">
        <span class="badge-number">Local</span>
        <span class="badge-label">Service Warranty</span>
      </div>
    </div>
  </div>
</section>

  </main>
</Layout>

<style is:global>



  /* I used is:global because these styles need to apply to the PriceFilter.jsx output */
  
  .category-page { padding: 40px 0 80px; background-color: #fcfcfc; }
  /* REPLACE YOUR EXISTING .container WITH THIS */
.container { 
  max-width: 1200px; 
  margin: 0 auto; 
  padding: 0 15px; /* Slightly smaller padding for mobile */
  width: 100%;
  box-sizing: border-box; 
}

  .cat-header h1 { color: #059669; font-size: 2.8rem; margin-bottom: 15px; font-weight: 800; }
  .intro-text { max-width: 850px; line-height: 1.7; color: #4b5563; font-size: 1.1rem; }

  /* --- THE SMART GRID --- */
  .product-grid { 
    display: grid; 
    grid-template-columns: repeat(2, 1fr); /* 2 columns on mobile */
    gap: 20px; 
    margin-top: 30px;
  }

  @media (min-width: 1024px) {
    .product-grid { 
      grid-template-columns: repeat(4, 1fr); /* 4 columns on desktop */
    }
  }

  /* --- THE UNIFORM CARD --- */
  .product-card { 
    background: white; 
    border: 1px solid #e5e7eb; 
    border-radius: 12px; 
    display: flex; 
    flex-direction: column; 
    height: 100%; /* Force equal height in a row */
    overflow: hidden; 
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .product-card:hover { 
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.05); 
  }

  .img-container { 
    aspect-ratio: 1 / 1; /* Makes the top image area perfectly square */
    padding: 15px; 
    background: #fff; 
    display: flex; 
    align-items: center; 
    justify-content: center;
    border-bottom: 1px solid #f3f4f6;
  }

  .img-container img { max-width: 100%; max-height: 100%; object-fit: contain; }

  .card-info { 
    padding: 15px; 
    display: flex; 
    flex-direction: column; 
    flex-grow: 1; /* Pushes content to fill the card */
  }

  .product-card h3 { 
    font-size: 1rem; 
    line-height: 1.4; 
    height: 2.8rem; /* Keeps titles aligned to exactly 2 lines */
    overflow: hidden; 
    margin-bottom: 8px; 
    color: #111827; 
  }

  .price { font-weight: 700; color: #059669; margin-bottom: 15px; font-size: 1.2rem; }

  /* --- BUTTONS --- */
  /* --- BUTTON CONTAINER --- */
.card-actions { 
  margin-top: auto; 
  display: flex; 
  flex-direction: column; 
  gap: 8px;
  width: 100%;
  padding-top: 10px;
}

/* --- THE UNIFORM BUTTON STYLE --- */
.btn-learn, .btn-whatsapp { 
  /* Centers text perfectly */
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center; 
  
  /* Forces all buttons to be the exact same height */
  height: 44px; 
  width: 100%;
  padding: 0 10px;
  border-radius: 8px; 
  text-decoration: none; 
  font-weight: 700;
  
  /* Shrinks font automatically on small screens */
  font-size: clamp(0.75rem, 2vw, 0.9rem);
  
  /* Keeps text on one line */
  white-space: nowrap;
  transition: all 0.2s ease;
  cursor: pointer;
  box-sizing: border-box;
}

/* Specific Colors */
.btn-learn { 
  background-color: #001f3f; 
  color: white !important;
}

.btn-whatsapp { 
  background-color: #25d366; 
  color: white !important;
}

/* Hover effects */
.btn-learn:hover, .btn-whatsapp:hover { 
  opacity: 0.9;
  transform: translateY(-1px);
}

/* --- UI ELEMENTS (Price Box & Trust Grid) --- */
.price-filter-box { 
  background: #fff; 
  border: 1px solid #e5e7eb; 
  padding: 25px; 
  border-radius: 12px; 
  margin-bottom: 30px; 
}

.trust-grid { 
  display: grid; 
  grid-template-columns: 1fr 1fr; 
  gap: 30px; 
  margin-top: 20px;
}

  
  @media (max-width: 768px) {
    .trust-grid { grid-template-columns: 1fr; }
    .cat-header h1 { font-size: 2rem; }
  }


  /* Social Buttons Styling */
.social-proof { 
  display: flex; 
  gap: 12px; 
  margin: 20px 0; 
}

.soc-btn { 
  padding: 10px 20px; 
  border-radius: 50px; 
  text-decoration: none; 
  color: white !important; /* Ensures text stays white */
  font-size: 0.9rem; 
  font-weight: bold; 
  transition: transform 0.2s, opacity 0.2s; 
  display: inline-block;
}

.fb { background: #1877F2; } /* Facebook Blue */
.yt { background: #FF0000; } /* YouTube Red */

.soc-btn:hover { 
  opacity: 0.9; 
  transform: scale(1.05); 
}


/* Container: Glassmorphism Effect */
.price-filter-box {
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(229, 231, 235, 0.5);
  padding: 30px;
  border-radius: 16px;
  margin-bottom: 40px;
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
}

/* Label & Current Price Styling */
.current-filter-label {
  display: block;
  font-size: 1.25rem;
  font-weight: 800;
  color: #1f2937;
  margin-bottom: 20px;
  letter-spacing: -0.025em;
}

.current-filter-label b {
  color: #059669; /* Your brand green */
  font-family: monospace;
  background: #ecfdf5;
  padding: 2px 8px;
  border-radius: 4px;
}

/* The Ultra-Modern Slider Track */
.price-range-input {
  -webkit-appearance: none;
  width: 100%;
  height: 8px;
  background: #e5e7eb;
  border-radius: 10px;
  outline: none;
  margin: 25px 0;
}

/* The Slider Thumb (The Circle) */
.price-range-input::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 24px;
  height: 24px;
  background: #059669;
  border: 4px solid #ffffff;
  border-radius: 50%;
  cursor: pointer;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.price-range-input::-webkit-slider-thumb:hover {
  transform: scale(1.2);
  background: #047857;
}

/* Min/Max Range Labels */
.range-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #9ca3af;
}

.count-text {
  margin-top: 15px;
  font-size: 0.9rem;
  color: #6b7280;
  font-style: italic;
}

/* SEO Guide: Added a soft shadow and better spacing */
.seo-guide { 
  margin: 60px 0; 
  padding: 40px; 
  background: #ffffff; 
  border-radius: 16px; 
  border: 1px solid #e5e7eb; 
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); /* Match your category explorer shadow */
}

.seo-guide h2 { 
  color: #001f3f; 
  margin-bottom: 20px; 
  font-size: 1.75rem; 
  font-weight: 800; 
  letter-spacing: -0.025em;
}

.seo-guide p { 
  color: #4b5563; 
  line-height: 1.8; 
  font-size: 1.05rem; 
}

/* FAQ Section: Stronger visual hierarchy */
.faq-section { margin-bottom: 80px; }

.faq-section h2 {
  color: #111827;
  font-size: 1.75rem;
  font-weight: 800;
  margin-bottom: 30px;
}

.faq-grid { 
  display: grid; 
  gap: 20px; 
}

/* FAQ Item: Matching your industrial green accent */
.faq-item { 
  background: #f9fafb; 
  padding: 25px; 
  border-radius: 12px; 
  border-left: 5px solid #059669; /* Your brand green */
  transition: transform 0.2s ease;
}

.faq-item:hover {
  transform: translateX(5px); /* Subtle interactive feel */
}

.faq-q { 
  color: #111827; 
  margin-bottom: 8px; 
  font-size: 1.1rem; 
}

.faq-a { 
  color: #4b5563; 
  font-size: 1rem; 
  line-height: 1.6;
}


.company-trust-footer {
  margin-top: 80px;
  padding: 60px 0;
  background-color: #001f3f; /* Deep Navy - represents stability and trust */
  color: white;
  border-radius: 20px;
}

.trust-content {
  max-width: 1000px;
  margin: 0 auto;
  padding: 0 20px;
  display: flex;
  gap: 50px;
  align-items: center;
}

.trust-text h2 {
  color: #ffffff;
  font-size: 2rem;
  margin-bottom: 20px;
}

.trust-text p {
  line-height: 1.7;
  color: #cbd5e1;
  margin-bottom: 25px;
}

.trust-points {
  list-style: none;
  padding: 0;
  margin-bottom: 30px;
}

.trust-points li {
  margin-bottom: 12px;
  font-size: 1.05rem;
}

.btn-about {
