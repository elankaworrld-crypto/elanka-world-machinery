---
const pathname = new URL(Astro.request.url).pathname;

const isActive = (path) => {
  if (path === '/') {
    return pathname === '/' || pathname === '';
  }
  if (path === '/shop') {
    return pathname.startsWith('/shop') || pathname.startsWith('/category/');
  }
  if (path === '/conveyor') {
    return pathname.startsWith('/conveyor') || pathname === '/conveyor-accessories' || pathname === '/conveyor-belts-only';
  }
  return pathname.startsWith(path);
};
