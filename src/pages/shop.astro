---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Fetch all products from the content collection
const allProducts = await getCollection('products');
---

<Layout title="Machinery Shop | E Lanka World">
  
  <main class="shop-container">
  <header class="shop-header">
    <h1>Shop for Packaging & Processing Machinery in Sri Lanka</h1>
    <h2>From E Lanka World International</h2>
    
    <p class="shop-intro">
      Shop for the very best <strong>packaging & processing machinery in Sri Lanka</strong>. 
      From <strong>Date coding machinery</strong> to <strong>sealing machinery</strong> to 
      grinders and many more. Unmatchable prices and unbeatable service. 
      Trusted by over 500 Sri Lankan manufacturers of various scale.
    </p>
  </header>
  
    
    <div class="product-grid">
      {allProducts.map((item) => (
        <div class="product-card">
          <div class="image-wrapper">
            <img src={item.data.image} alt={item.data.title} loading="lazy" />
          </div>
          
          <div class="info">
            <h3>{item.data.title}</h3>
            

            <div class="price-container">
              {item.data.offerPrice ? (
                <p class="price-text sale">{item.data.offerPrice}</p>
              ) : (
                <p class="price-text">{item.data.price}</p>
              )}
            </div>

            <div class="card-actions">
              <a href={`/products/${item.id}`} class="btn view-btn">
                View Details
              </a>

              <a 
                href={`https://wa.me/94776344758?text=I am interested in the ${item.data.title}. Please provide more details.`} 
                class="btn whatsapp-btn"
                target="_blank"
                rel="noopener noreferrer"
              >
                <img 
                  src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" 
                  alt="WhatsApp" 
                  width="18" 
                  height="18" 
                />
                Ask on WhatsApp
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </main>

</Layout>

<style>
  
  .shop-container { 
  max-width: 1200px; 
  margin: 0 auto; 
  padding: 40px 15px; /* Slightly smaller padding for mobile */
  text-align: center; 
  width: 100%;
  box-sizing: border-box; /* Essential: keeps padding inside the width */
}

  h1 {
    color: #111827;
    font-size: 2.5rem;
    margin-bottom: 10px;
  }

  .product-grid {
  display: grid;
  /* Use 1fr on mobile, then 280px on larger screens */
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
  gap: 20px;
  padding: 0;
  margin-top: 30px;
  width: 100%;
}

  .product-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }

  .image-wrapper {
    height: 220px;
    background: #fdfdfd;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 15px;
    border-bottom: 1px solid #f3f4f6;
  }

  .image-wrapper img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .info { padding: 20px; flex-grow: 1; }

  h3 { 
  font-size: 1.15rem; 
  color: #111827; 
  margin-bottom: 15px; 
  /* These 4 lines lock the height for exactly 2 lines of text */
  height: 3.2rem; 
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

  .category-list { 
    display: flex; 
    flex-wrap: wrap; 
    gap: 5px; 
    margin-bottom: 12px; 
  }

  .badge { 
    font-size: 0.7rem; 
    background: #eff6ff; 
    color: #1e40af; 
    padding: 2px 8px; 
    border-radius: 4px; 
    font-weight: 600; 
  }

  .price-text { 
    font-size: 1.25rem; 
    font-weight: 800; 
    color: #059669; 
    margin-bottom: 15px; 
  }

  .price-text.sale { color: #d946ef; }

  .card-actions { 
    display: flex; 
    flex-direction: column; 
    gap: 8px; 
  }

  .btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    transition: all 0.2s;
    cursor: pointer;
    border: none;
  }

  .view-btn { 
    background: #001f3f; 
    color: white; 
  }

  .view-btn:hover { background: #002d5c; }

  .whatsapp-btn { 
    background: #25D366; 
    color: white; 
  }

  .whatsapp-btn:hover { 
    background: #128c7e; 
    transform: scale(1.02);
  }
</style>